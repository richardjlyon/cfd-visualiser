# Copy to .env and fill in for local dev; NEVER commit .env.
# All values shown are placeholders — replace with real secrets from each service.

# Healthchecks.io ping URL (dead-man's switch) — PIPE-05
# Source: healthchecks.io -> Projects -> (default) -> your check -> Ping URL
PIPELINE_HC_URL=https://hc-ping.com/CHANGE-ME

# Cloudflare Pages deploy (used by daily.yml in CI; not needed locally)
# Source: Cloudflare dashboard -> My Profile -> API Tokens -> Create Token
#         Custom token: Account > Cloudflare Pages > Edit, scoped to one account
CF_API_TOKEN=

# Source: Cloudflare dashboard -> any zone or account page -> right sidebar -> Account ID
CF_ACCOUNT_ID=

# Cloudflare Web Analytics token (OPS-05) — injected into dist/ HTML at deploy time
# Source: Cloudflare dashboard -> Analytics & Logs -> Web Analytics -> Add a site
#         -> select cfd-visualiser -> copy the token from the JS beacon snippet
CF_WEB_ANALYTICS_TOKEN=
